{
  "name": "pos-universal",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:3000/login && electron electron/main.js\"",
    "electron:start": "electron electron/main.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "autoprefixer": "^10.5.2",
    "bcryptjs": "^2.4.3",
    "next": "^16.2.9",
    "node-forge": "^1.4.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.17",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.0",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wait-on": "^9.0.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
