# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================================================
# URL de conexión a la base de datos (MySQL/MariaDB).
# Reemplazar con credenciales productivas reales y seguras.
DATABASE_URL="mysql://usuario_prod:password_seguro@localhost:3306/nombre_db?allowPublicKeyRetrieval=true&connection_limit=10"

# ==============================================================================
# AUTENTICACIÓN Y SEGURIDAD
# ==============================================================================
# Secreto obligatorio para firmar y validar las cookies de sesión del usuario.
# Debe ser un string aleatorio y largo en producción (ej. npx auth secret o openssl rand -base64 32).
AUTH_SECRET="cambiar-por-un-secreto-muy-seguro-en-produccion"

# Secreto opcional para encriptar los access tokens y refresh tokens de Mercado Pago en la DB.
# Si no se configura, el sistema usará AUTH_SECRET como fallback automático para garantizar la encriptación.
TOKEN_ENCRYPTION_SECRET="cambiar-por-un-secreto-de-encriptacion-diferente"

# ==============================================================================
# SETUP Y ADMINISTRACIÓN DE COMERCIOS
# ==============================================================================
# Clave maestra para acceder a la creación/edición de comercios (/setup/business).
SETUP_ADMIN_KEY="clave-maestra-para-creacion-de-comercios-2026"

# Determina si el panel de creación de comercios (/setup/business) está activo.
# Poner en false en producción para bloquear cualquier alta externa.
ENABLE_SETUP_PAGE=true

# ==============================================================================
# URLS DE LA APLICACIÓN
# ==============================================================================
# URL pública de la aplicación para redirecciones y webhooks (ej: https://foxpoint.com).
# En desarrollo local con Mercado Pago se suele configurar la URL de ngrok.
APP_PUBLIC_URL="http://localhost:3000"

# ==============================================================================
# INTEGRACIÓN CON MERCADO PAGO (AISLADA POR COMERCIO CON OAUTH)
# ==============================================================================
# Credenciales de la aplicación Mercado Pago (del integrador/plataforma).
# Estas credenciales se usan para iniciar el flujo de conexión OAuth de cada comercio.
MP_CLIENT_ID="tu-client-id-de-mercado-pago"
MP_CLIENT_SECRET="tu-client-secret-de-mercado-pago"

# URI de redirección registrada exactamente igual en la consola de Mercado Pago.
# Debe terminar en /api/mercadopago/oauth/callback.
MP_REDIRECT_URI="http://localhost:3000/api/mercadopago/oauth/callback"
