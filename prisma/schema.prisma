generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  CASHIER
  VIEWER
}

enum BusinessType {
  KIOSK
  GROCERY
  SUPERMARKET
  BUTCHER
  GREENGROCER
  BEVERAGE_STORE
  HARDWARE_STORE
  PET_SHOP
  BOOKSTORE
  CLOTHING_STORE
  BAZAAR
  OTHER
}

enum UnitType {
  UNIT
  KG
  GR
  LITER
  METER
  PACK
  BOX
  OTHER
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  TRANSFER
  MERCADOPAGO
  CURRENT_ACCOUNT
}

enum MercadoPagoOperationMode {
  MANUAL
  API_QR
}

enum MercadoPagoEnvironment {
  SANDBOX
  PRODUCTION
}

enum MercadoPagoConnectionType {
  MANUAL_TOKEN
  OAUTH
}

enum PaymentProvider {
  MERCADOPAGO
}

enum PaymentAttemptStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  ERROR
}

enum PaymentAttemptOrigin {
  QR_ORDER
  AMOUNT_MATCH
  MANUAL_REFERENCE
}

enum SaleStatus {
  PAID
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  INCOME
  EXPENSE
  CASH_WITHDRAWAL
  CASH_ADJUSTMENT
}

enum CustomerAccountMovementType {
  DEBIT
  PAYMENT
  ADJUSTMENT
  SALE_CANCELLED
}

enum StockMovementType {
  SALE
  MANUAL_ADJUSTMENT
  PURCHASE
  WASTE
  INITIAL_IMPORT
}

enum PurchaseStatus {
  RECEIVED
  CANCELLED
}

enum PrintPaperSize {
  TICKET_80
  TICKET_58
  A4
}

enum FiscalStatus {
  NOT_REQUESTED
  PENDING
  READY_TO_ISSUE
  ISSUED
  FAILED
  CANCELLED_BEFORE_ISSUE
  CREDIT_NOTE_REQUIRED
  CANCELLED_BY_CREDIT_NOTE
}

enum FiscalDocumentStatus {
  DRAFT
  PENDING
  ISSUED
  FAILED
  CANCELLED
  CREDIT_NOTE_PENDING
  CREDIT_NOTE_ISSUED
}

enum FiscalDocumentType {
  INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum FiscalDocumentLetter {
  A
  B
  C
  M
  E
}

enum FiscalEnvironment {
  HOMOLOGACION
  PRODUCCION
}

enum FiscalIssueMode {
  ASK
  AUTO
  NEVER
}

enum FiscalCustomerCondition {
  CONSUMIDOR_FINAL
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  NO_RESPONSABLE
  EXTERIOR
  OTHER
}

enum FiscalDocumentIdentityType {
  DNI
  CUIT
  CUIL
  CDI
  PASAPORTE
  CONSUMIDOR_FINAL
  OTHER
}

enum FiscalTaxTreatment {
  TAXED
  EXEMPT
  NON_TAXABLE
}

model Business {
  id              String   @id @default(cuid())
  name            String
  legalName       String?
  tradeName       String?
  taxId           String?
  fiscalCondition String?
  phone           String?
  email           String?
  address         String?
  logoUrl         String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users                 User[]
  products              Product[]
  categories            Category[]
  customers             Customer[]
  suppliers             Supplier[]
  sales                 Sale[]
  saleNumberSequences   SaleNumberSequence[]
  paymentAttempts       PaymentAttempt[]
  cashSessions          CashSession[]
  businessProfile       BusinessProfile?
  paymentMethodSettings PaymentMethodSetting[]
  mercadoPagoAccounts   MercadoPagoAccount[]
  printSettings         PrintSetting[]
  ticketSettings        TicketSetting[]
  cashRegisterSettings  CashRegisterSetting[]
  stockSettings         StockSetting[]
  fiscalSettings        FiscalSetting[]
  quotes                Quote[]
  auditLogs             AuditLog[]
  stockMovements        StockMovement[]
  purchases             Purchase[]
}

model User {
  id                 String                    @id @default(cuid())
  name               String
  email              String                    @unique
  passwordHash       String
  role               Role
  active             Boolean                   @default(true)
  businessId         String?
  business           Business?                 @relation(fields: [businessId], references: [id], onDelete: Restrict)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  sales              Sale[]                    @relation("SaleUser")
  cancelledSales     Sale[]                    @relation("SaleCancelledBy")
  openedCashSessions CashSession[]             @relation("CashSessionOpenedBy")
  closedCashSessions CashSession[]             @relation("CashSessionClosedBy")
  cashMovements      CashMovement[]
  stockMovements     StockMovement[]
  customerMovements  CustomerAccountMovement[]
  purchases          Purchase[]
  quotes             Quote[]                   @relation("QuoteCreatedBy")
  auditLogs          AuditLog[]
  fiscalEvents       FiscalEvent[]
  associatedPayments PaymentAttempt[]          @relation("PaymentAttemptAssociatedBy")

  @@index([role])
  @@index([businessId])
}

model BusinessProfile {
  id                String       @id @default(cuid())
  businessId        String       @unique
  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name              String
  businessType      BusinessType @default(KIOSK)
  cuit              String?
  address           String?
  phone             String?
  email             String?
  fiscalCondition   String?
  grossIncome       String?
  activityStartDate DateTime?
  currency          String       @default("ARS")
  locale            String       @default("es-AR")
  timezone          String       @default("America/Argentina/Buenos_Aires")
  preferredTheme    String?
  logoUrl           String?
  website           String?
  generalFooterText String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model PaymentMethodSetting {
  businessId            String
  business              Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  method                PaymentMethod
  label                 String
  enabled               Boolean                  @default(true)
  sortOrder             Int                      @default(0)
  instructions          String?                  @db.Text
  alias                 String?
  cbu                   String?
  cvu                   String?
  accountHolder         String?
  accountCuit           String?
  bankName              String?
  qrImageDataUrl        String?                  @db.LongText
  askReference          Boolean                  @default(false)
  defaultProviderStatus String?
  surchargeRate         Decimal?                 @db.Decimal(5, 2)
  fixedSurcharge        Decimal?                 @db.Decimal(12, 2)
  mercadoPagoMode       MercadoPagoOperationMode @default(MANUAL)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@id([businessId, method])
  @@index([enabled])
  @@index([sortOrder])
}

model MercadoPagoAccount {
  id                          String                 @id @default(cuid())
  businessId                  String
  business                    Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name                        String
  enabled                     Boolean                @default(true)
  connectionType              MercadoPagoConnectionType @default(MANUAL_TOKEN)
  environment                 MercadoPagoEnvironment @default(SANDBOX)
  accessToken                 String                 @db.Text
  oauthRefreshToken           String?                @db.Text
  oauthTokenExpiresAt         DateTime?
  oauthScope                  String?                @db.Text
  oauthConnectedAt            DateTime?
  oauthLastRefreshAt          DateTime?
  oauthRequiresReconnect      Boolean                @default(false)
  mpUserId                    String?
  publicKey                   String?
  collectorId                 String?
  accountNickname             String?
  accountEmail                String?
  storeId                     String?
  externalStoreId             String?
  storeName                   String?
  posId                       String?
  externalPosId               String?
  posName                     String?
  posCategory                 String?
  posCreatedAt                DateTime?
  lastPosSetupAt              DateTime?
  lastPosSetupStep            String?
  lastPosSetupStatus          String?
  lastPosSetupError           String?                @db.Text
  lastConnectionTestAt        DateTime?
  lastConnectionStatus        String?
  lastConnectionMessage       String?                @db.Text
  defaultAccount              Boolean                @default(false)
  instructions                String?                @db.Text
  enableAmountMatching        Boolean                @default(false)
  amountMatchingWindowMinutes Int                    @default(10)
  amountMatchingTolerance     Decimal                @default(0) @db.Decimal(12, 2)
  amountMatchingAutoApprove   Boolean                @default(false)
  amountMatchingPollSeconds   Int                    @default(20)
  showRecentMovements         Boolean                @default(true)
  deletedAt                   DateTime?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  paymentAttempts             PaymentAttempt[]

  @@index([enabled, deletedAt])
  @@index([defaultAccount])
  @@index([connectionType])
  @@index([oauthRequiresReconnect])
  @@index([businessId])
}

model CreditInstallmentPlan {
  id            String   @id @default(cuid())
  installments  Int      @unique
  surchargeRate Decimal  @db.Decimal(5, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active])
}

model PrintSetting {
  id              String         @id @default(cuid())
  businessId      String         @unique
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  printerName     String?
  paperSize       PrintPaperSize @default(TICKET_80)
  silentPrint     Boolean        @default(false)
  autoPrintTicket Boolean        @default(false)
  copies          Int            @default(1)
  marginMm        Int            @default(2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model TicketSetting {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  showBusinessName    Boolean  @default(true)
  showCuit            Boolean  @default(true)
  showAddress         Boolean  @default(true)
  showPhone           Boolean  @default(true)
  showEmail           Boolean  @default(false)
  showSeller          Boolean  @default(true)
  showCustomer        Boolean  @default(true)
  showPaymentDetails  Boolean  @default(true)
  showStockUnit       Boolean  @default(true)
  showBarcode         Boolean  @default(false)
  footerText          String?
  headerText          String?
  ticketTitle         String   @default("Ticket no fiscal")
  thankYouText        String   @default("Gracias por su compra")
  showNonFiscalLegend Boolean  @default(true)
  nonFiscalLegend     String   @default("Ticket no fiscal")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CashRegisterSetting {
  id                        String   @id @default(cuid())
  businessId                String   @unique
  business                  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requireOpenSession        Boolean  @default(true)
  showExpectedCashToCashier Boolean  @default(false)
  allowCashierCancelSale    Boolean  @default(false)
  allowNegativeStock        Boolean  @default(false)
  defaultSearchMode         String?
  quickProductsLimit        Int      @default(12)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model StockSetting {
  id                         String   @id @default(cuid())
  businessId                 String   @unique
  business                   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lowStockEnabled            Boolean  @default(true)
  defaultMinStock            Decimal? @db.Decimal(12, 3)
  allowManualStockAdjustment Boolean  @default(true)
  showLowStockWarnings       Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model FiscalSetting {
  id                         String                     @id @default(cuid())
  businessId                 String                     @unique
  business                   Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  enabled                    Boolean                    @default(false)
  environment                FiscalEnvironment          @default(HOMOLOGACION)
  cuit                       String?
  legalName                  String?
  fiscalCondition            FiscalCustomerCondition?
  pointOfSale                Int?
  defaultInvoiceLetter       FiscalDocumentLetter?
  cashIssueMode              FiscalIssueMode            @default(ASK)
  electronicPaymentIssueMode FiscalIssueMode            @default(AUTO)
  currentAccountIssueMode    FiscalIssueMode            @default(ASK)
  pendingWarningMinutes      Int                        @default(30)
  pendingCriticalMinutes     Int                        @default(120)
  allowCancelBeforeIssue     Boolean                    @default(true)
  requireCustomerForInvoiceA Boolean                    @default(true)
  defaultCustomerDocType     FiscalDocumentIdentityType @default(CONSUMIDOR_FINAL)
  defaultVatRate             Decimal?                   @db.Decimal(5, 2)
  defaultVatArcaCode         Int?
  defaultTaxTreatment        FiscalTaxTreatment?
  arcaCertificatePem         String?                    @db.Text
  arcaPrivateKeyPem          String?                    @db.Text
  arcaWsaaToken              String?                    @db.Text
  arcaWsaaSign               String?                    @db.Text
  arcaTokenExpiresAt         DateTime?
  arcaLastConnectionStatus   String?
  arcaLastConnectionTestAt   DateTime?
  arcaLastWsfeStatus         String?
  arcaLastWsfeTestAt         DateTime?
  arcaLastError              String?                    @db.Text
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
}

model FiscalDocument {
  id                      String                      @id @default(cuid())
  saleId                  String?
  sale                    Sale?                       @relation("FiscalDocumentSale", fields: [saleId], references: [id], onDelete: SetNull)
  primaryForSale          Sale?                       @relation("SalePrimaryFiscalDocument")
  type                    FiscalDocumentType
  letter                  FiscalDocumentLetter
  status                  FiscalDocumentStatus        @default(DRAFT)
  environment             FiscalEnvironment           @default(HOMOLOGACION)
  pointOfSale             Int?
  number                  Int?
  cae                     String?
  caeDueDate              DateTime?
  issueDate               DateTime?
  total                   Decimal                     @db.Decimal(12, 2)
  netAmount               Decimal?                    @db.Decimal(12, 2)
  vatAmount               Decimal?                    @db.Decimal(12, 2)
  exemptAmount            Decimal?                    @db.Decimal(12, 2)
  nonTaxedAmount          Decimal?                    @db.Decimal(12, 2)
  customerName            String?
  customerDocType         FiscalDocumentIdentityType?
  customerDocNumber       String?
  customerCondition       FiscalCustomerCondition?
  relatedFiscalDocumentId String?
  relatedFiscalDocument   FiscalDocument?             @relation("FiscalDocumentRelated", fields: [relatedFiscalDocumentId], references: [id], onDelete: SetNull)
  relatedFiscalDocuments  FiscalDocument[]            @relation("FiscalDocumentRelated")
  requestJson             Json?
  responseJson            Json?
  errorMessage            String?                     @db.Text
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  items                   FiscalDocumentItem[]
  events                  FiscalEvent[]

  @@index([saleId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([relatedFiscalDocumentId])
}

model FiscalDocumentItem {
  id               String              @id @default(cuid())
  fiscalDocumentId String
  fiscalDocument   FiscalDocument      @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)
  description      String
  quantity         Decimal             @db.Decimal(12, 3)
  unitPrice        Decimal             @db.Decimal(12, 2)
  subtotal         Decimal             @db.Decimal(12, 2)
  vatRate          Decimal?            @db.Decimal(5, 2)
  taxCode          String?
  taxTreatment     FiscalTaxTreatment?

  @@index([fiscalDocumentId])
}

model FiscalEvent {
  id               String          @id @default(cuid())
  saleId           String?
  sale             Sale?           @relation(fields: [saleId], references: [id], onDelete: SetNull)
  fiscalDocumentId String?
  fiscalDocument   FiscalDocument? @relation(fields: [fiscalDocumentId], references: [id], onDelete: SetNull)
  type             String
  message          String          @db.Text
  metadata         Json?
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  @@index([saleId])
  @@index([fiscalDocumentId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  entity      String
  entityId    String?
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@index([businessId])
}

model Category {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  parentId   String?
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children   Category[] @relation("CategoryHierarchy")
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  products   Product[]

  @@unique([businessId, name])
  @@index([active])
  @@index([parentId])
  @@index([businessId])
}

model Product {
  id                    String              @id @default(cuid())
  businessId            String
  business              Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name                  String
  barcode               String?
  sku                   String?
  brand                 String?
  categoryId            String
  category              Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  salePrice             Decimal             @db.Decimal(12, 2)
  cost                  Decimal?            @db.Decimal(12, 2)
  stock                 Decimal             @default(0) @db.Decimal(12, 3)
  minStock              Decimal             @default(0) @db.Decimal(12, 3)
  unitType              UnitType            @default(UNIT)
  allowsDecimalQuantity Boolean             @default(false)
  vatRate               Decimal?            @db.Decimal(5, 2)
  vatArcaCode           Int?
  taxTreatment          FiscalTaxTreatment?
  quickAccess           Boolean             @default(false)
  active                Boolean             @default(true)
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  saleItems             SaleItem[]
  quoteItems            QuoteItem[]
  stockMovements        StockMovement[]
  purchaseItems         PurchaseItem[]

  @@unique([businessId, barcode])
  @@unique([businessId, sku])
  @@index([categoryId])
  @@index([active, deletedAt])
  @@index([name])
  @@index([businessId])
}

model Customer {
  id               String                      @id @default(cuid())
  businessId       String
  business         Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name             String
  document         String?
  phone            String?
  email            String?
  address          String?
  fiscalCondition  FiscalCustomerCondition?
  docType          FiscalDocumentIdentityType?
  docNumber        String?
  businessName     String?
  taxAddress       String?
  notes            String?
  active           Boolean                     @default(true)
  deletedAt        DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  sales            Sale[]
  quotes           Quote[]
  accountMovements CustomerAccountMovement[]

  @@index([name])
  @@index([document])
  @@index([phone])
  @@index([active, deletedAt])
  @@index([businessId])
}

model Quote {
  id                       String      @id @default(cuid())
  businessId               String
  business                 Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  quoteNumber              Int         @unique @default(autoincrement())
  customerId               String?
  customer                 Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerNameSnapshot     String
  customerDocumentSnapshot String?
  customerPhoneSnapshot    String?
  customerEmailSnapshot    String?
  status                   QuoteStatus @default(DRAFT)
  subtotal                 Decimal     @db.Decimal(12, 2)
  discountTotal            Decimal     @default(0) @db.Decimal(12, 2)
  surchargeTotal           Decimal     @default(0) @db.Decimal(12, 2)
  total                    Decimal     @db.Decimal(12, 2)
  validUntil               DateTime?
  notes                    String?     @db.Text
  terms                    String?     @db.Text
  createdById              String
  createdBy                User        @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  items                    QuoteItem[]

  @@index([customerId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([validUntil])
  @@index([businessId])
}

model QuoteItem {
  id                  String   @id @default(cuid())
  quoteId             String
  quote               Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productNameSnapshot String
  quantity            Decimal  @db.Decimal(12, 3)
  unitPrice           Decimal  @db.Decimal(12, 2)
  subtotal            Decimal  @db.Decimal(12, 2)
  unitTypeSnapshot    UnitType
  notes               String?

  @@index([quoteId])
  @@index([productId])
}

model Sale {
  id                         String                      @id @default(cuid())
  businessId                 String
  business                   Business                    @relation(fields: [businessId], references: [id], onDelete: Restrict)
  saleNumber                 Int                         @unique @default(autoincrement())
  internalNumber             Int
  internalPeriod             String                      @db.VarChar(7)
  total                      Decimal                     @db.Decimal(12, 2)
  subtotal                   Decimal                     @db.Decimal(12, 2)
  discountTotal              Decimal                     @default(0) @db.Decimal(12, 2)
  surchargeTotal             Decimal                     @default(0) @db.Decimal(12, 2)
  generalSurchargeType       String?                     @db.VarChar(16)
  generalSurchargeValue      Decimal?                    @db.Decimal(12, 4)
  generalSurchargeAmount     Decimal                     @default(0) @db.Decimal(12, 2)
  status                     SaleStatus                  @default(PAID)
  userId                     String
  user                       User                        @relation("SaleUser", fields: [userId], references: [id], onDelete: Restrict)
  customerId                 String?
  customer                   Customer?                   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashSessionId              String?
  cashSession                CashSession?                @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  cancelledAt                DateTime?
  cancelledById              String?
  cancelledBy                User?                       @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancellationReason         String?
  requiresFiscalInvoice      Boolean                     @default(false)
  fiscalStatus               FiscalStatus                @default(NOT_REQUESTED)
  fiscalRequestedAt          DateTime?
  fiscalIssuedAt             DateTime?
  fiscalCancelledAt          DateTime?
  fiscalFailureReason        String?                 @db.Text
  fiscalDocumentId           String?                     @unique
  fiscalDocument             FiscalDocument?             @relation("SalePrimaryFiscalDocument", fields: [fiscalDocumentId], references: [id], onDelete: SetNull)
  fiscalCustomerNameSnapshot String?
  fiscalCustomerDocType      FiscalDocumentIdentityType?
  fiscalCustomerDocNumber    String?
  fiscalCustomerCondition    FiscalCustomerCondition?
  fiscalNotes                String?
  clientOperationId          String?
  occurredAt                 DateTime                    @default(now())
  offlineSyncedAt            DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  items                      SaleItem[]
  payments                   Payment[]
  paymentAttempts            PaymentAttempt[]
  accountMovements           CustomerAccountMovement[]
  fiscalDocuments            FiscalDocument[]            @relation("FiscalDocumentSale")
  fiscalEvents               FiscalEvent[]

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([customerId])
  @@index([cashSessionId])
  @@index([cancelledById])
  @@index([fiscalStatus])
  @@index([requiresFiscalInvoice])
  @@index([occurredAt])
  @@index([businessId])
  @@index([businessId, internalPeriod])
  @@unique([businessId, internalPeriod, internalNumber])
  @@unique([businessId, clientOperationId])
}

model SaleNumberSequence {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  period      String   @db.VarChar(7)
  lastNumber  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, period])
  @@index([businessId])
}

model CustomerAccountMovement {
  id              String                      @id @default(cuid())
  customerId      String
  customer        Customer                    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  saleId          String?
  sale            Sale?                       @relation(fields: [saleId], references: [id], onDelete: SetNull)
  type            CustomerAccountMovementType
  amount          Decimal                     @db.Decimal(12, 2)
  previousBalance Decimal                     @db.Decimal(12, 2)
  newBalance      Decimal                     @db.Decimal(12, 2)
  reason          String
  paymentMethod   PaymentMethod?
  userId          String
  user            User                        @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt       DateTime                    @default(now())

  @@index([customerId])
  @@index([saleId])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
}

model CashSession {
  id                 String            @id @default(cuid())
  businessId         String
  business           Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  openedAt           DateTime          @default(now())
  closedAt           DateTime?
  openingAmount      Decimal           @db.Decimal(12, 2)
  expectedCashAmount Decimal?          @db.Decimal(12, 2)
  countedCashAmount  Decimal?          @db.Decimal(12, 2)
  differenceAmount   Decimal?          @db.Decimal(12, 2)
  notes              String?
  status             CashSessionStatus @default(OPEN)
  openedById         String
  openedBy           User              @relation("CashSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedById         String?
  closedBy           User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  movements          CashMovement[]
  sales              Sale[]

  @@index([status])
  @@index([openedAt])
  @@index([openedById])
  @@index([closedById])
  @@index([businessId])
}

model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  type          CashMovementType
  amount        Decimal          @db.Decimal(12, 2)
  reason        String
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt     DateTime         @default(now())

  @@index([cashSessionId])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
}

model SaleItem {
  id                  String   @id @default(cuid())
  saleId              String
  sale                Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product? @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  unitPrice           Decimal  @db.Decimal(12, 2)
  quantity            Decimal  @db.Decimal(12, 3)
  subtotal            Decimal  @db.Decimal(12, 2)
  unitTypeSnapshot    UnitType
  isManual            Boolean  @default(false)

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id                String          @id @default(cuid())
  saleId            String
  sale              Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method            PaymentMethod
  amount            Decimal         @db.Decimal(12, 2)
  receivedAmount    Decimal?        @db.Decimal(12, 2)
  changeAmount      Decimal?        @db.Decimal(12, 2)
  installments      Int?
  surchargeRate     Decimal?        @db.Decimal(5, 2)
  surchargeAmount   Decimal?        @db.Decimal(12, 2)
  externalId        String?
  externalReference String?
  providerStatus    String?
  paymentAttemptId  String?         @unique
  paymentAttempt    PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())

  @@index([saleId])
  @@index([method])
  @@index([paymentAttemptId])
}

model PaymentAttempt {
  id                   String               @id @default(cuid())
  businessId           String
  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleId               String?
  sale                 Sale?                @relation(fields: [saleId], references: [id], onDelete: SetNull)
  method               PaymentMethod        @default(MERCADOPAGO)
  provider             PaymentProvider      @default(MERCADOPAGO)
  mercadoPagoAccountId String
  mercadoPagoAccount   MercadoPagoAccount   @relation(fields: [mercadoPagoAccountId], references: [id], onDelete: Restrict)
  payment              Payment?
  externalReference    String               @unique
  providerOrderId      String?
  providerPaymentId    String?
  amount               Decimal              @db.Decimal(12, 2)
  status               PaymentAttemptStatus @default(PENDING)
  origin               PaymentAttemptOrigin
  qrData               String?              @db.Text
  checkoutUrl          String?
  rawStatus            String?
  rawStatusDetail      String?
  lastCheckedAt        DateTime?
  approvedAt           DateTime?
  associatedByUserId   String?
  associatedByUser     User?                @relation("PaymentAttemptAssociatedBy", fields: [associatedByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([saleId])
  @@index([mercadoPagoAccountId])
  @@index([providerOrderId])
  @@index([providerPaymentId])
  @@index([status])
  @@index([origin])
  @@index([createdAt])
  @@index([associatedByUserId])
  @@index([businessId])
}

model StockMovement {
  id            String            @id @default(cuid())
  businessId    String
  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  previousStock Decimal           @db.Decimal(12, 3)
  newStock      Decimal           @db.Decimal(12, 3)
  reason        String?
  referenceId   String?
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())

  @@index([createdAt])
  @@index([productId])
  @@index([type])
  @@index([userId])
  @@index([businessId])
}

model Supplier {
  id        String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  cuit       String?
  phone      String?
  email      String?
  address    String?
  notes      String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([name])
  @@index([cuit])
  @@index([phone])
  @@index([active])
  @@index([businessId])
}

model Purchase {
  id             String         @id @default(cuid())
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  purchaseNumber Int            @unique @default(autoincrement())
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  total          Decimal        @db.Decimal(12, 2)
  notes          String?
  status         PurchaseStatus @default(RECEIVED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          PurchaseItem[]

  @@index([supplierId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([businessId])
}

model PurchaseItem {
  id                  String   @id @default(cuid())
  purchaseId          String
  purchase            Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  quantity            Decimal  @db.Decimal(12, 3)
  unitCost            Decimal  @db.Decimal(12, 2)
  subtotal            Decimal  @db.Decimal(12, 2)

  @@index([purchaseId])
  @@index([productId])
}
