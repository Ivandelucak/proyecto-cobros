generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CASHIER
}

enum BusinessType {
  KIOSK
  GROCERY
  SUPERMARKET
  BUTCHER
  GREENGROCER
  BEVERAGE_STORE
  HARDWARE_STORE
  PET_SHOP
  BOOKSTORE
  CLOTHING_STORE
  BAZAAR
  OTHER
}

enum UnitType {
  UNIT
  KG
  GR
  LITER
  METER
  PACK
  BOX
  OTHER
}

enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  TRANSFER
  MERCADOPAGO
  CURRENT_ACCOUNT
}

enum SaleStatus {
  PAID
  CANCELLED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  INCOME
  EXPENSE
  CASH_WITHDRAWAL
  CASH_ADJUSTMENT
}

enum CustomerAccountMovementType {
  DEBIT
  PAYMENT
  ADJUSTMENT
  SALE_CANCELLED
}

enum StockMovementType {
  SALE
  MANUAL_ADJUSTMENT
  PURCHASE
  WASTE
  INITIAL_IMPORT
}

enum PurchaseStatus {
  RECEIVED
  CANCELLED
}

enum PrintPaperSize {
  TICKET_80
  TICKET_58
  A4
}

model User {
  id                 String          @id @default(cuid())
  name               String
  email              String          @unique
  passwordHash       String
  role               Role
  active             Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sales              Sale[]          @relation("SaleUser")
  cancelledSales     Sale[]          @relation("SaleCancelledBy")
  openedCashSessions CashSession[]   @relation("CashSessionOpenedBy")
  closedCashSessions CashSession[]   @relation("CashSessionClosedBy")
  cashMovements      CashMovement[]
  stockMovements     StockMovement[]
  customerMovements  CustomerAccountMovement[]
  purchases          Purchase[]
  auditLogs          AuditLog[]

  @@index([role])
}

model BusinessProfile {
  id                 String       @id
  name               String
  businessType       BusinessType @default(KIOSK)
  cuit               String?
  address            String?
  phone              String?
  email              String?
  fiscalCondition    String?
  grossIncome        String?
  activityStartDate  DateTime?
  currency           String       @default("ARS")
  locale             String       @default("es-AR")
  timezone           String       @default("America/Argentina/Buenos_Aires")
  preferredTheme     String?
  logoUrl            String?
  website            String?
  generalFooterText  String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model PaymentMethodSetting {
  method    PaymentMethod @id
  label     String
  enabled   Boolean       @default(true)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([enabled])
  @@index([sortOrder])
}

model CreditInstallmentPlan {
  id            String   @id @default(cuid())
  installments  Int      @unique
  surchargeRate Decimal  @db.Decimal(5, 2)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active])
}

model PrintSetting {
  id              String         @id
  printerName     String?
  paperSize       PrintPaperSize @default(TICKET_80)
  silentPrint     Boolean        @default(false)
  autoPrintTicket Boolean        @default(false)
  copies          Int            @default(1)
  marginMm        Int            @default(2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model TicketSetting {
  id                  String   @id
  showBusinessName    Boolean  @default(true)
  showCuit            Boolean  @default(true)
  showAddress         Boolean  @default(true)
  showPhone           Boolean  @default(true)
  showEmail           Boolean  @default(false)
  showSeller          Boolean  @default(true)
  showCustomer        Boolean  @default(true)
  showPaymentDetails  Boolean  @default(true)
  showStockUnit       Boolean  @default(true)
  showBarcode         Boolean  @default(false)
  footerText          String?
  headerText          String?
  ticketTitle         String   @default("Ticket no fiscal")
  thankYouText        String   @default("Gracias por su compra")
  showNonFiscalLegend Boolean  @default(true)
  nonFiscalLegend     String   @default("Ticket no fiscal")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CashRegisterSetting {
  id                           String   @id
  requireOpenSession           Boolean  @default(true)
  showExpectedCashToCashier    Boolean  @default(false)
  allowCashierCancelSale       Boolean  @default(false)
  allowNegativeStock           Boolean  @default(false)
  defaultSearchMode            String?
  quickProductsLimit           Int      @default(12)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model StockSetting {
  id                         String   @id
  lowStockEnabled            Boolean  @default(true)
  defaultMinStock            Decimal? @db.Decimal(12, 3)
  allowManualStockAdjustment Boolean  @default(true)
  showLowStockWarnings       Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  entity      String
  entityId    String?
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryHierarchy")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  products  Product[]

  @@index([active])
  @@index([parentId])
}

model Product {
  id                    String          @id @default(cuid())
  name                  String
  barcode               String?         @unique
  sku                   String?         @unique
  brand                 String?
  categoryId            String
  category              Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  salePrice             Decimal         @db.Decimal(12, 2)
  cost                  Decimal?        @db.Decimal(12, 2)
  stock                 Decimal         @default(0) @db.Decimal(12, 3)
  minStock              Decimal         @default(0) @db.Decimal(12, 3)
  unitType              UnitType        @default(UNIT)
  allowsDecimalQuantity Boolean         @default(false)
  quickAccess           Boolean         @default(false)
  active                Boolean         @default(true)
  deletedAt             DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  saleItems             SaleItem[]
  stockMovements        StockMovement[]
  purchaseItems         PurchaseItem[]

  @@index([categoryId])
  @@index([active, deletedAt])
  @@index([name])
}

model Customer {
  id               String                    @id @default(cuid())
  name             String
  document         String?
  phone            String?
  email            String?
  address          String?
  notes            String?
  active           Boolean                   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  sales            Sale[]
  accountMovements CustomerAccountMovement[]

  @@index([name])
  @@index([document])
  @@index([phone])
  @@index([active, deletedAt])
}

model Sale {
  id                 String       @id @default(cuid())
  saleNumber         Int          @unique @default(autoincrement())
  total              Decimal      @db.Decimal(12, 2)
  subtotal           Decimal      @db.Decimal(12, 2)
  discountTotal      Decimal      @default(0) @db.Decimal(12, 2)
  surchargeTotal     Decimal      @default(0) @db.Decimal(12, 2)
  status             SaleStatus   @default(PAID)
  userId             String
  user               User         @relation("SaleUser", fields: [userId], references: [id], onDelete: Restrict)
  customerId         String?
  customer           Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashSessionId      String?
  cashSession        CashSession? @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  cancelledAt        DateTime?
  cancelledById      String?
  cancelledBy        User?        @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancellationReason String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  items              SaleItem[]
  payments           Payment[]
  accountMovements   CustomerAccountMovement[]

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([customerId])
  @@index([cashSessionId])
  @@index([cancelledById])
}

model CustomerAccountMovement {
  id              String                      @id @default(cuid())
  customerId      String
  customer        Customer                    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  saleId          String?
  sale            Sale?                       @relation(fields: [saleId], references: [id], onDelete: SetNull)
  type            CustomerAccountMovementType
  amount          Decimal                     @db.Decimal(12, 2)
  previousBalance Decimal                     @db.Decimal(12, 2)
  newBalance      Decimal                     @db.Decimal(12, 2)
  reason          String
  paymentMethod   PaymentMethod?
  userId          String
  user            User                        @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt       DateTime                    @default(now())

  @@index([customerId])
  @@index([saleId])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
}

model CashSession {
  id                 String            @id @default(cuid())
  openedAt           DateTime          @default(now())
  closedAt           DateTime?
  openingAmount      Decimal           @db.Decimal(12, 2)
  expectedCashAmount Decimal?          @db.Decimal(12, 2)
  countedCashAmount  Decimal?          @db.Decimal(12, 2)
  differenceAmount   Decimal?          @db.Decimal(12, 2)
  notes              String?
  status             CashSessionStatus @default(OPEN)
  openedById         String
  openedBy           User              @relation("CashSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedById         String?
  closedBy           User?             @relation("CashSessionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  movements          CashMovement[]
  sales              Sale[]

  @@index([status])
  @@index([openedAt])
  @@index([openedById])
  @@index([closedById])
}

model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  cashSession   CashSession      @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  type          CashMovementType
  amount        Decimal          @db.Decimal(12, 2)
  reason        String
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt     DateTime         @default(now())

  @@index([cashSessionId])
  @@index([type])
  @@index([userId])
  @@index([createdAt])
}

model SaleItem {
  id                  String   @id @default(cuid())
  saleId              String
  sale                Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  unitPrice           Decimal  @db.Decimal(12, 2)
  quantity            Decimal  @db.Decimal(12, 3)
  subtotal            Decimal  @db.Decimal(12, 2)
  unitTypeSnapshot    UnitType

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id                String        @id @default(cuid())
  saleId            String
  sale              Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)
  receivedAmount    Decimal?      @db.Decimal(12, 2)
  changeAmount      Decimal?      @db.Decimal(12, 2)
  installments      Int?
  surchargeRate     Decimal?      @db.Decimal(5, 2)
  surchargeAmount   Decimal?      @db.Decimal(12, 2)
  externalId        String?
  externalReference String?
  providerStatus    String?
  createdAt         DateTime      @default(now())

  @@index([saleId])
  @@index([method])
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  previousStock Decimal           @db.Decimal(12, 3)
  newStock      Decimal           @db.Decimal(12, 3)
  reason        String?
  referenceId   String?
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())

  @@index([createdAt])
  @@index([productId])
  @@index([type])
  @@index([userId])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  cuit      String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([name])
  @@index([cuit])
  @@index([phone])
  @@index([active])
}

model Purchase {
  id             String         @id @default(cuid())
  purchaseNumber Int            @unique @default(autoincrement())
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  total          Decimal        @db.Decimal(12, 2)
  notes          String?
  status         PurchaseStatus @default(RECEIVED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  items          PurchaseItem[]

  @@index([supplierId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseItem {
  id                  String   @id @default(cuid())
  purchaseId          String
  purchase            Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productNameSnapshot String
  quantity            Decimal  @db.Decimal(12, 3)
  unitCost            Decimal  @db.Decimal(12, 2)
  subtotal            Decimal  @db.Decimal(12, 2)

  @@index([purchaseId])
  @@index([productId])
}
